# Copy this file to ".env" for local dev and fill in real values.
# In production you set these in your host's dashboard (Render/Railway), NOT in a file.

# Your PostgreSQL connection string (from Supabase/Neon).
# LEAVE BLANK to run the API in DEMO mode (signups accepted but not stored,
# live telemetry still streams). The site works either way.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Which site(s) may call this API (your frontend URL).
# Comma-separate multiple. Use http://localhost:5500 while testing locally.
# Leave blank to allow any origin (fine for local/demo; lock it down in prod).
ALLOWED_ORIGIN=http://localhost:5500

# Port (most hosts set this automatically; 8080 is a safe local default).
PORT=8080

# "production" in prod, anything else => development behaviour.
NODE_ENV=development
